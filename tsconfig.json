{
  "compilerOptions": {
    "target": "ES2022",
    "ignoreDeprecations":"6.0",
    "noImplicitAny": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "declaration": true,
    "isolatedModules":true,
    "noEmit":true,
    "module": "esnext",
    "moduleResolution": "node",
    "types": ["node"],
    "strict": true,
    "outDir": "dist",
    "paths": {
      "@core/*": ["./src/core/*"]
    },
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}